# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<appName>

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your-jwt-secret-minimum-32-characters-here
JWT_REFRESH_SECRET=your-refresh-secret-minimum-32-characters

# CORS
CORS_ORIGIN=http://localhost:3000

# Cloudinary (image storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# WhatsApp Business API (Meta)
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-permanent-token

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxx

# SuperAdmin seed account
SUPERADMIN_EMAIL=superadmin@chronosvault.com
SUPERADMIN_PASSWORD=your-superadmin-password

# Resend Email Service
# RESEND_API_KEY: API key from your Resend dashboard (https://resend.com/api-keys)
# Used for sending transactional emails (OTP, order confirmations, status updates)
RESEND_API_KEY=re_ZpogCYrF_HeHn1MY77ABpCVZXHu8emJTE

# RESEND_FROM_EMAIL: Verified sender email address in format "Name <email@domain.com>"
# Domain must be verified in your Resend account before sending emails
RESEND_FROM_EMAIL=chronocraft.rk@gmail.com
